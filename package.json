{
  "name": "multibank-automation",
  "version": "1.0.0",
  "description": "Production-grade Playwright automation framework for MultiBank trading platform",
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:all-browsers": "playwright test",
    "test:headed": "playwright test --headed --project=chromium",
    "test:debug": "playwright test --debug --project=chromium",
    "test:ui": "playwright test --ui",
    "test:navigation": "playwright test --grep @navigation --project=chromium",
    "test:trading": "playwright test --grep @trading --project=chromium",
    "test:content": "playwright test --grep @content --project=chromium",
    "test:report": "playwright show-report reports/html",
    "task2": "ts-node task2/stringFrequency.ts",
    "task2:test": "playwright test --grep @task2 --project=chromium --reporter=list",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}